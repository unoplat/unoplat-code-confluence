{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.unoplat.io/schemas/custom-framework-lib-schema-v4.json",
  "title": "Unoplat Code Confluence Deterministic Interface Discovery Schema (DIDS) v4",
  "description": "Framework and library capability signatures grouped by programming language.",
  "type": "object",
  "propertyNames": {
    "$ref": "#/$defs/languageEnum"
  },
  "patternProperties": {
    "^[a-z]+$": {
      "$ref": "#/$defs/languageBlock"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "languageEnum": {
      "type": "string",
      "description": "Allowed lower-case language identifiers.",
      "enum": [
        "python",
        "javascript",
        "typescript",
        "java",
        "go"
      ]
    },
    "languageBlock": {
      "type": "object",
      "description": "All libraries and frameworks implemented in a single language.",
      "patternProperties": {
        "^.+$": {
          "$ref": "#/$defs/libraryDef"
        }
      },
      "additionalProperties": false
    },
    "libraryDef": {
      "type": "object",
      "required": [
        "docs_url",
        "capabilities"
      ],
      "properties": {
        "docs_url": {
          "type": "string",
          "format": "uri",
          "description": "Canonical documentation URL."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the library."
        },
        "version": {
          "type": "string",
          "description": "Library version used to verify patterns (optional)."
        },
        "capabilities": {
          "type": "object",
          "minProperties": 1,
          "description": "Architectural capability families keyed by enum value.",
          "propertyNames": {
            "$ref": "#/$defs/capabilityFamilyEnum"
          },
          "patternProperties": {
            "^.+$": {
              "$ref": "#/$defs/capabilityDef"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "capabilityDef": {
      "type": "object",
      "required": [
        "description",
        "operations"
      ],
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable explanation of the architectural capability."
        },
        "docs_url": {
          "type": "string",
          "format": "uri",
          "description": "Capability-specific documentation URL (optional)."
        },
        "operations": {
          "type": "object",
          "minProperties": 1,
          "description": "Architectural operations grouped beneath a capability family.",
          "propertyNames": {
            "$ref": "#/$defs/operationKindEnum"
          },
          "patternProperties": {
            "^.+$": {
              "$ref": "#/$defs/operationDef"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "operationDef": {
      "type": "object",
      "required": [
        "description",
        "detectors"
      ],
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable explanation of the architectural operation."
        },
        "docs_url": {
          "type": "string",
          "format": "uri",
          "description": "Operation-specific documentation URL (optional)."
        },
        "startpoint": {
          "type": "boolean",
          "description": "Indicates whether the operation represents an application entry point, such as route registration or message consumption.",
          "default": false
        },
        "notes": {
          "type": "string",
          "description": "Contributor notes, caveats, or grouping guidance for the operation."
        },
        "detectors": {
          "type": "object",
          "minProperties": 1,
          "description": "Precise detector definitions keyed by contributor-chosen local identifier.",
          "propertyNames": {
            "$ref": "#/$defs/detectorKeyDef"
          },
          "patternProperties": {
            "^.+$": {
              "$ref": "#/$defs/detectorDef"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "detectorKeyDef": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Lowercase detector identifier scoped to a single operation."
    },
    "detectorDef": {
      "type": "object",
      "required": [
        "absolute_paths",
        "target_level",
        "concept"
      ],
      "properties": {
        "description": {
          "type": "string",
          "description": "Optional explanation of what this detector specifically matches."
        },
        "docs_url": {
          "type": "string",
          "format": "uri",
          "description": "Detector-specific documentation URL (optional)."
        },
        "absolute_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "description": "Fully-qualified symbols identifying the import paths used by this precise detector.",
          "items": {
            "type": "string",
            "pattern": "^(?:@?[A-Za-z_][\\w-]*)(?:[./:][A-Za-z_][\\w-]*)*\\.[A-Za-z_][\\w]*$"
          }
        },
        "target_level": {
          "$ref": "#/$defs/targetLevelEnum"
        },
        "concept": {
          "$ref": "#/$defs/conceptEnum"
        },
        "construct_query": {
          "$ref": "#/$defs/constructQueryDef"
        },
        "base_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Contributor-authored confidence for CallExpression detector definitions only; lower values indicate higher ambiguity and should include disambiguation guidance in notes."
        },
        "notes": {
          "type": "string",
          "description": "Contributor notes, caveats, links, or disambiguation guidance."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "concept": {
                "const": "CallExpression"
              }
            }
          },
          "then": {
            "properties": {
              "target_level": {
                "const": "function"
              }
            },
            "required": [
              "base_confidence"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "concept": {
                "const": "CallExpression"
              },
              "base_confidence": {
                "type": "number",
                "exclusiveMaximum": 0.7
              }
            },
            "required": [
              "concept",
              "base_confidence"
            ]
          },
          "then": {
            "required": [
              "notes"
            ],
            "properties": {
              "notes": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "concept": {
                "not": {
                  "const": "CallExpression"
                }
              }
            },
            "required": [
              "concept"
            ]
          },
          "then": {
            "not": {
              "required": [
                "base_confidence"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "concept": {
                "const": "Inheritance"
              }
            }
          },
          "then": {
            "properties": {
              "target_level": {
                "const": "class"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "concept": {
                "const": "FunctionDefinition"
              }
            }
          },
          "then": {
            "properties": {
              "target_level": {
                "const": "function"
              }
            }
          }
        }
      ]
    },
    "capabilityFamilyEnum": {
      "type": "string",
      "description": "Library-agnostic architectural capability family.",
      "enum": [
        "rest_api",
        "graphql_api",
        "grpc_server",
        "websocket_server",
        "sse_server",
        "webhook_receiver",
        "webhook_sender",
        "cli_command",
        "scheduler",
        "background_worker",
        "file_watcher",
        "mqtt_server",
        "tcp_server",
        "udp_server",
        "http_client",
        "graphql_client",
        "grpc_client",
        "websocket_client",
        "email_service",
        "message_broker",
        "job_queue",
        "change_data_capture",
        "relational_database",
        "document_database",
        "key_value_store",
        "wide_column_store",
        "graph_database",
        "multi_model_database",
        "vector_store",
        "file_storage",
        "object_storage",
        "authentication",
        "authorization",
        "configuration",
        "secret_management",
        "observability",
        "telemetry",
        "logging",
        "llm_inference",
        "mcp_server",
        "data_model",
        "web_component"
      ]
    },
    "operationKindEnum": {
      "type": "string",
      "description": "Architectural operation grouped within a capability family.",
      "enum": [
        "initialize",
        "configure",
        "register_handler",
        "compose_router",
        "expose_tool",
        "expose_resource",
        "consume",
        "publish",
        "enqueue",
        "schedule",
        "listen",
        "connect",
        "disconnect",
        "query",
        "read",
        "write",
        "update",
        "delete",
        "upload",
        "download",
        "emit",
        "invoke",
        "sign_in",
        "sign_out",
        "sign_up",
        "observe_state",
        "authorize",
        "model",
        "field",
        "relationship",
        "validate",
        "serialize",
        "deserialize",
        "execute"
      ]
    },
    "targetLevelEnum": {
      "type": "string",
      "enum": [
        "function",
        "class"
      ],
      "description": "Granularity of the code element that owns the detector."
    },
    "conceptEnum": {
      "type": "string",
      "enum": [
        "AnnotationLike",
        "CallExpression",
        "Inheritance",
        "FunctionDefinition"
      ],
      "description": "Language-agnostic construct category used by the precise detector."
    },
    "constructQueryDef": {
      "type": "object",
      "description": "Optional refinements to the auto-generated Tree-sitter query. Allowed keys depend on the detector's concept.",
      "properties": {
        "method_regex": {
          "type": "string"
        },
        "annotation_name_regex": {
          "type": "string"
        },
        "attribute_regex": {
          "type": "string"
        },
        "callee_regex": {
          "type": "string"
        },
        "superclass_regex": {
          "type": "string"
        },
        "function_name_regex": {
          "type": "string"
        },
        "export_name_regex": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
