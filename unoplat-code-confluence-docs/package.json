{
  "name": "unoplat-code-confluence-docs",
  "version": "0.45.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "prebuild": "node ./scripts/sync-framework-definitions.mjs",
    "build": "NODE_ENV=production vp build",
    "preview": "vp preview",
    "start": "vp preview",
    "sync:framework-definitions": "node ./scripts/sync-framework-definitions.mjs",
    "check:framework-definitions": "bun run sync:framework-definitions && [ -z \"$(git status --porcelain -- public/framework-definitions content/docs/contribution/custom-framework-schema/catalog)\" ]",
    "types:check": "bun run sync:framework-definitions && fumadocs-mdx && tsc --noEmit",
    "postinstall": "bun run sync:framework-definitions && fumadocs-mdx"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-router": "1.143.4",
    "@tanstack/react-router-devtools": "1.143.4",
    "@tanstack/react-start": "1.143.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/start-static-server-functions": "1.143.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "feed": "^5.2.1",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "16.5.4",
    "lucide-react": "^0.555.0",
    "lucide-static": "^0.552.0",
    "motion": "^10.18.0",
    "postcss": "^8.5.15",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24"
  },
  "devDependencies": {
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-svgr": "^4.5.0",
    "vite-plus": "0.1.24"
  },
  "packageManager": "bun@1.3.14",
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  }
}
