FROM node:22-bookworm-slim

LABEL org.opencontainers.image.source="https://github.com/unoplat/unoplat-code-confluence"

ENV PATH="/root/.bun/bin:${PATH}"

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        python3 \
        ripgrep \
        unzip \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g corepack@latest \
    && corepack enable \
    && curl -fsSL https://bun.sh/install | bash

WORKDIR /workspace

CMD ["sleep", "infinity"]
